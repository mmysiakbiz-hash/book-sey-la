# book-sey-la — environment variables
# Copy to .env.local for local dev, and set the same in Vercel → Project → Settings → Environment Variables.

# --- Supabase (public, safe in the browser; RLS enforces access) ---
NEXT_PUBLIC_SUPABASE_URL=https://eoapvjnaievxqkbmtxar.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Brevo transactional email (SERVER SECRET — do NOT prefix with NEXT_PUBLIC) ---
# Used by /api/book (booking confirmation) AND /api/auth/magic-link (sign-in).
# Sender hello@sey.la must be a verified sender/domain in Brevo, or sends fail
# with "sender not valid". Brevo → SMTP & API → API Keys.
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Supabase service role (SERVER SECRET — never NEXT_PUBLIC, never sent to client) ---
# Powers /api/auth/magic-link: generates the sign-in link server-side and emails
# it via Brevo, so magic-link delivery does NOT depend on Supabase Custom SMTP.
# Supabase → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# --- Reminders cron (server secret) ---
# Protects GET /api/cron/reminders. Vercel Cron sends this automatically as a
# Bearer token when set; external schedulers can send the same header or ?token=.
CRON_SECRET=

# --- Review links (server secret) ---
# Signs the tokens in review-request emails (/review/<id>?t=...). Falls back to
# CRON_SECRET if unset, so setting CRON_SECRET alone is enough. Server-only.
REVIEW_SECRET=

# --- Admin tools (server secret) ---
# Gates /admin/prospect (create a pre-listed page for a prospect) via /api/prospect.
ADMIN_TOKEN=

# --- Email deliverability test (optional, server secret) ---
# When set, enables the gated test-send at:
#   GET /api/health/email?to=you@example.com&token=<this-value>
# Leave unset in normal operation to disable the test-send path.
EMAIL_TEST_TOKEN=
