# book-sey-la — environment variables
# Copy to .env.local for local dev, and set the same in Vercel → Project → Settings → Environment Variables.

# --- Supabase (public, safe in the browser; RLS enforces access) ---
NEXT_PUBLIC_SUPABASE_URL=https://eoapvjnaievxqkbmtxar.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Brevo transactional email (SERVER SECRET — do NOT prefix with NEXT_PUBLIC) ---
# Used by /api/book (booking confirmation). Sender hello@sey.la must be a
# verified sender/domain in Brevo, or sends fail with "sender not valid".
# Brevo → SMTP & API → API Keys.
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Email deliverability test (optional, server secret) ---
# When set, enables the gated test-send at:
#   GET /api/health/email?to=you@example.com&token=<this-value>
# Leave unset in normal operation to disable the test-send path.
EMAIL_TEST_TOKEN=
